# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Vite Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# JWT Configuration
VITE_ACCESS_TOKEN_EXPIRY=your_access_token_expiry
VITE_REFRESH_TOKEN_EXPIRY=your_refresh_token_expiry

# Local Storage Keys
VITE_USER_STORAGE_KEY=your_user_storage_key
VITE_TOKEN_EXPIRY_KEY=your_token_expiry_key